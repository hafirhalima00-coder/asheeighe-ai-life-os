# asheeighe Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
ASHEEIGHE_API_BASE_URL=https://api.asheeighe.app/v1
ASHEEIGHE_API_TIMEOUT=30000

# Authentication
ASHEEIGHE_JWT_SECRET=your-jwt-secret-here
ASHEEIGHE_JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# AI Providers (at least one required)
ASHEEIGHE_OPENAI_API_KEY=
ASHEEIGHE_GEMINI_API_KEY=
ASHEEIGHE_ANTHROPIC_API_KEY=
ASHEEIGHE_OLLAMA_BASE_URL=http://localhost:11434
ASHEEIGHE_OPENROUTER_API_KEY=

# Composio
ASHEEIGHE_COMPOSIO_API_KEY=
ASHEEIGHE_COMPOSIO_BASE_URL=https://backend.composio.dev/api

# OAuth Providers
ASHEEIGHE_GOOGLE_CLIENT_ID=
ASHEEIGHE_APPLE_CLIENT_ID=

# Flavor
ASHEEIGHE_APP_ENV=development
