# PINKZ Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
PINKZ_API_BASE_URL=https://api.pinkz.app/v1
PINKZ_API_TIMEOUT=30000

# Authentication
PINKZ_JWT_SECRET=your-jwt-secret-here
PINKZ_JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# AI Providers (at least one required)
PINKZ_OPENAI_API_KEY=
PINKZ_GEMINI_API_KEY=
PINKZ_ANTHROPIC_API_KEY=
PINKZ_OLLAMA_BASE_URL=http://localhost:11434
PINKZ_OPENROUTER_API_KEY=

# Composio
PINKZ_COMPOSIO_API_KEY=
PINKZ_COMPOSIO_BASE_URL=https://backend.composio.dev/api

# OAuth Providers
PINKZ_GOOGLE_CLIENT_ID=
PINKZ_APPLE_CLIENT_ID=

# Flavor
PINKZ_APP_ENV=development
