{
  "name": "pinkz-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "wrangler dev --config workers/api/wrangler.jsonc",
    "dev:auth": "wrangler dev --config workers/auth/wrangler.jsonc",
    "dev:composio": "wrangler dev --config workers/composio/wrangler.jsonc",
    "dev:sync": "wrangler dev --config workers/sync/wrangler.jsonc",
    "deploy:api": "wrangler deploy --config workers/api/wrangler.jsonc",
    "deploy:auth": "wrangler deploy --config workers/auth/wrangler.jsonc",
    "deploy:composio": "wrangler deploy --config workers/composio/wrangler.jsonc",
    "deploy:sync": "wrangler deploy --config workers/sync/wrangler.jsonc",
    "db:migrate": "wrangler d1 migrations apply pinkz-db",
    "db:generate": "wrangler d1 migrations create",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "hono": "^4.7.7",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250415.0",
    "@types/jsonwebtoken": "^9.0.9",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "wrangler": "^4.14.0"
  }
}
