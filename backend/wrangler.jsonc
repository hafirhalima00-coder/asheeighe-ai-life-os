{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "asheeighe-backend",
  "main": "workers/api/src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "asheeighe-db",
      "database_id": "f162983e-bf08-40e0-99ab-17a8ed24b20d",
      "migrations_dir": "schemas"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "64a4380ca01a4bf18e2b799eb5ff690a",
      "preview_id": "64a4380ca01a4bf18e2b799eb5ff690a"
    }
  ],
  "vars": {
    "JWT_SECRET": "",
    "JWT_REFRESH_SECRET": "",
    "OPENAI_API_KEY": "",
    "GEMINI_API_KEY": "",
    "ANTHROPIC_API_KEY": "",
    "OLLAMA_BASE_URL": "http://localhost:11434",
    "OPENROUTER_API_KEY": "",
    "COMPOSIO_API_KEY": "",
    "COMPOSIO_BASE_URL": "https://backend.composio.dev/api",
    "APP_URL": "http://localhost:8787"
  }
}
